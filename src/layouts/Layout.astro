---
import "../styles/global.css";

const { title = "Tareo", breadcrumb = "" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} — Sistema de Tareo</title>
		<meta
			name="description"
			content="Sistema de tareo laboral - PAUSER DISTRIBUCIONES S.A.C."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<!-- Supabase config para scripts del layout -->
		<meta
			name="sb-url"
			content={import.meta.env.PUBLIC_SUPABASE_URL ?? ""}
		/>
		<meta
			name="sb-key"
			content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ""}
		/>
		<script is:inline>
			const theme = window.localStorage.getItem("pt_theme") || "dark";
			if (theme === "light")
				document.documentElement.classList.add("theme-light");
		</script>
	</head>
	<body>
		<div class="layout">
			<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar__logo">
					<h1>PAUSER TAREO</h1>
					<p id="sidebarOrgName">PAUSER DISTRIBUCIONES S.A.C.</p>
				</div>
				<nav class="sidebar__nav">
					<div class="nav-section">
						<div class="nav-section__title">Principal</div>
						<!-- Nav items se renderizan dinámicamente por rol via JS -->
						<div id="sidebarNav"></div>
					</div>
				</nav>
				<div class="sidebar__footer">v1.0 · 2026</div>
			</aside>

			<!-- Main -->
			<div class="main-content">
				<header class="topbar">
					<div class="topbar__breadcrumb">
						Sistema de Tareo &nbsp;/&nbsp; <span
							>{breadcrumb || title}</span
						>
					</div>
					<div class="topbar__actions">
						<span
							style="font-size:12px;color:var(--color-text-muted)"
						>
							{
								new Date().toLocaleDateString("es-PE", {
									weekday: "long",
									year: "numeric",
									month: "long",
									day: "numeric",
								})
							}
						</span>
						<!-- Selector Global de Periodo -->
						<div
							class="topbar-periodo"
							style="display:flex;align-items:center;gap:6px;background:var(--color-surface-2);padding:4px 8px;border-radius:6px;border:1px solid var(--color-border);margin-right:12px"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								width="14"
								height="14"
								style="color:var(--color-text-muted)"
								><rect
									x="3"
									y="4"
									width="18"
									height="18"
									rx="2"
									ry="2"></rect><line
									x1="16"
									y1="2"
									x2="16"
									y2="6"></line><line
									x1="8"
									y1="2"
									x2="8"
									y2="6"></line><line
									x1="3"
									y1="10"
									x2="21"
									y2="10"></line></svg
							>
							<select
								id="global-mes"
								style="background:transparent;border:none;color:var(--color-text);font-size:12px;font-weight:600;outline:none;cursor:pointer;padding-right:4px"
							>
								<option value="1">Enero</option><option
									value="2">Febrero</option
								><option value="3">Marzo</option><option
									value="4">Abril</option
								><option value="5">Mayo</option><option
									value="6">Junio</option
								><option value="7">Julio</option><option
									value="8">Agosto</option
								><option value="9">Septiembre</option><option
									value="10">Octubre</option
								><option value="11">Noviembre</option><option
									value="12">Diciembre</option
								>
							</select>
							<select
								id="global-anio"
								style="background:transparent;border:none;color:var(--color-text);font-size:12px;font-weight:600;outline:none;cursor:pointer"
							>
								<!-- Opciones generadas dinámicamente por JS -->
							</select>
						</div>
						<!-- Theme Toggle -->
						<button
							id="themeToggleBtn"
							class="btn btn--ghost"
							style="padding:6px; font-size:16px; margin-right:4px;"
							title="Cambiar tema"
						>
							<svg
								id="themeIconDark"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								width="16"
								height="16"
								><path
									d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
								></path></svg
							>
							<svg
								id="themeIconLight"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								width="16"
								height="16"
								style="display:none;"
								><circle cx="12" cy="12" r="5"></circle><line
									x1="12"
									y1="1"
									x2="12"
									y2="3"></line><line
									x1="12"
									y1="21"
									x2="12"
									y2="23"></line><line
									x1="4.22"
									y1="4.22"
									x2="5.64"
									y2="5.64"></line><line
									x1="18.36"
									y1="18.36"
									x2="19.78"
									y2="19.78"></line><line
									x1="1"
									y1="12"
									x2="3"
									y2="12"></line><line
									x1="21"
									y1="12"
									x2="23"
									y2="12"></line><line
									x1="4.22"
									y1="19.78"
									x2="5.64"
									y2="18.36"></line><line
									x1="18.36"
									y1="5.64"
									x2="19.78"
									y2="4.22"></line></svg
							>
						</button>
						<div class="topbar-user" id="topbarUser"></div>
						<button
							class="btn btn--ghost topbar-logout"
							id="logoutBtn"
							style="font-size:12px;padding:5px 10px;display:none"
						>
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								width="14"
								height="14"
							>
								<path
									d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
								></path>
								<polyline points="16 17 21 12 16 7"></polyline>
								<line x1="21" y1="12" x2="9" y2="12"></line>
							</svg>
							Salir
						</button>
					</div>
				</header>
				<main class="page-content">
					<slot />
				</main>
			</div>
		</div>
		<!-- ── Guard de sesión + logout ── -->
		<script>
			// @ts-nocheck
			(function () {
				var SESSION_KEY = "pt_auth";
				var raw = window.sessionStorage.getItem(SESSION_KEY);

				// Sin sesión → redirigir al login
				if (!raw) {
					window.location.href = "/login";
					return;
				}

				var user;
				try {
					user = JSON.parse(raw);
				} catch (_) {
					return;
				}

				// Mostrar usuario en topbar
				var userEl = document.getElementById("topbarUser");
				if (userEl && user.nombre) {
					userEl.innerHTML =
						'<div style="display:flex;align-items:center;gap:8px;">' +
						'<div style="width:28px;height:28px;border-radius:50%;background:rgba(79,142,247,0.2);border:1px solid rgba(79,142,247,0.4);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--color-primary);">' +
						user.nombre.charAt(0).toUpperCase() +
						"</div>" +
						"<div>" +
						'<div style="font-size:12px;font-weight:600;color:var(--color-text)">' +
						user.nombre.split(" ")[0] +
						"</div>" +
						'<div style="font-size:10px;color:var(--color-text-muted)">' +
						(user.sede || "") +
						(user.business_unit ? " / " + user.business_unit : "") +
						"</div>" +
						"</div></div>";
				}

				// Construir sidebar según rol
				var nav = document.getElementById("sidebarNav");
				var cp = window.location.pathname;
				var ia = function (href) {
					return href === "/" ? cp === "/" : cp.startsWith(href);
				};
				var svgGrid =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>';
				var svgFile =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
				var svgUsers =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>';
				var svgPct =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>';
				var svgLayrs =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>';
				var svgGear =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
				var svgKey =
					'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6M15.5 7.5l3 3"/></svg>';

				var nl = function (href, icon, label, badgeId, isSub) {
					var badge = badgeId
						? '<span id="' +
							badgeId +
							'" style="display:none;background:var(--color-warning);color:#000;font-size:10px;font-weight:800;border-radius:20px;padding:1px 6px"></span>'
						: "";
					var activeClass = ia(href) ? "active" : "";
					var subClass = isSub ? "sub" : "";
					return (
						'<a href="' +
						href +
						'" class="nav-link ' +
						activeClass +
						" " +
						subClass +
						'">' +
						(icon ? icon : "") +
						'<span style="display:flex;align-items:center;gap:6px;flex:1">' +
						label +
						badge +
						"</span></a>"
					);
				};

				if (nav) {
					// ── Leer Periodo Global ──
					var d = new Date();
					var pAnio = d.getFullYear();
					var pMes = d.getMonth() + 1;
					var rawPeriodo =
						window.sessionStorage.getItem("pt_periodo");
					if (rawPeriodo) {
						try {
							var pe = JSON.parse(rawPeriodo);
							pAnio = pe.anio || pAnio;
							pMes = pe.mes || pMes;
						} catch (e) {}
					} else {
						window.sessionStorage.setItem(
							"pt_periodo",
							JSON.stringify({ anio: pAnio, mes: pMes }),
						);
					}

					// Set UI selectors + Generar años dinámicamente
					var gMes = document.getElementById("global-mes");
					var gAnio = document.getElementById("global-anio");

					if (gAnio) {
						var dAnio = new Date().getFullYear();
						var htmlAnios = "";
						for (var i = dAnio - 1; i <= dAnio + 3; i++) {
							htmlAnios +=
								'<option value="' + i + '">' + i + "</option>";
						}
						gAnio.innerHTML = htmlAnios;
					}

					if (gMes) gMes.value = String(pMes);
					if (gAnio) gAnio.value = String(pAnio);

					// Listeners
					var onPeriodoChange = function () {
						if (!gMes || !gAnio) return;
						var nuevoPe = {
							anio: parseInt(gAnio.value),
							mes: parseInt(gMes.value),
						};
						window.sessionStorage.setItem(
							"pt_periodo",
							JSON.stringify(nuevoPe),
						);
						// Mejora 7: Emitir CustomEvent para que React escuche sin polling
						window.dispatchEvent(
							new CustomEvent("pt:periodo-changed", {
								detail: nuevoPe,
							}),
						);
						// Si estamos en una ruta de tareo específico por año/mes, cambiar la URL
						var pathParts = window.location.pathname.split("/");
						if (
							pathParts.length >= 4 &&
							(pathParts[2] === "analista" ||
								window.location.pathname.startsWith(
									"/tareo/",
								)) &&
							!isNaN(parseInt(pathParts[pathParts.length - 1]))
						) {
							// No recargamos aquí para no romper Astro SSG si no existe, pero en nuestro caso react lee del session
							window.location.reload();
						} else {
							window.location.reload();
						}
					};
					if (gMes) gMes.addEventListener("change", onPeriodoChange);
					if (gAnio)
						gAnio.addEventListener("change", onPeriodoChange);

					var anioMesParam = "?anio=" + pAnio + "&mes=" + pMes;
					var isJefeOrCentral =
						user.rol === "jefe" ||
						(user.rol === "analista" &&
							user.sede === "ADM. CENTRAL");

					if (isJefeOrCentral) {
						var enlacesJefe = "";
						if (user.rol === "jefe") {
							enlacesJefe = nl(
								"/usuarios",
								svgKey,
								"Usuarios",
								null,
							);
						}

						nav.innerHTML =
							nl("/", svgGrid, "Dashboard", null) +
							'<div style="margin-top:6px; margin-bottom:6px;">' +
							nl("/tareo", svgLayrs, "TAREO", null) +
							'<div class="nav-submenu">' +
							nl("/tareo/jefe", "", "Tareo / Sede", null, true) +
							nl(
								"/tareo/maestro" + anioMesParam,
								"",
								"Tareo Maestro",
								null,
								true,
							) +
							(user.rol === "analista"
								? nl(
										"/tareo/analista",
										"",
										"Mi Tareo",
										"badge-en-revision",
										true,
									)
								: "") +
							"</div>" +
							"</div>" +
							nl(
								"/empleados",
								svgUsers,
								"Trabajadores",
								"badge-trabajadores",
							) +
							nl("/afp", svgPct, "Tasas AFP", null) +
							enlacesJefe;
					} else {
						nav.innerHTML =
							nl("/", svgGrid, "Dashboard", null) +
							'<div style="margin-top:6px; margin-bottom:6px;">' +
							nl("/tareo", svgLayrs, "TAREO", null) +
							'<div class="nav-submenu">' +
							nl(
								"/tareo/analista",
								"",
								"Mi Tareo",
								"badge-en-revision",
								true,
							) +
							"</div>" +
							"</div>" +
							nl(
								"/empleados",
								svgUsers,
								"Trabajadores",
								"badge-trabajadores",
							) +
							nl("/afp", svgPct, "Tasas AFP", null);
					}
				}

				// Botón salir
				var logoutBtn = document.getElementById("logoutBtn");
				if (logoutBtn) {
					logoutBtn.style.display = "inline-flex";
					logoutBtn.addEventListener("click", function () {
						window.sessionStorage.removeItem(SESSION_KEY);
						window.location.href = "/login";
					});
				}

				// Lógica del modo oscuro/claro
				var themeBtn = document.getElementById("themeToggleBtn");
				var iconDark = document.getElementById("themeIconDark");
				var iconLight = document.getElementById("themeIconLight");

				function updateThemeUI() {
					var isLight =
						document.documentElement.classList.contains(
							"theme-light",
						);
					if (isLight) {
						if (iconDark) iconDark.style.display = "none";
						if (iconLight) iconLight.style.display = "block";
					} else {
						if (iconDark) iconDark.style.display = "block";
						if (iconLight) iconLight.style.display = "none";
					}
				}

				if (themeBtn) {
					updateThemeUI();
					themeBtn.addEventListener("click", function () {
						document.documentElement.classList.toggle(
							"theme-light",
						);
						var isLight =
							document.documentElement.classList.contains(
								"theme-light",
							);
						window.localStorage.setItem(
							"pt_theme",
							isLight ? "light" : "dark",
						);
						updateThemeUI();
					});
				}
			})();
		</script>

		<!-- ── Badge de empleados sin config tareo (JEFE) + Badge obs (ANALISTA) ── -->
		<script type="module">
			async function actualizarBadge() {
				var sbUrl = document.querySelector(
					'meta[name="sb-url"]',
				)?.content;
				var sbKey = document.querySelector(
					'meta[name="sb-key"]',
				)?.content;
				if (!sbUrl || !sbKey || sbKey.startsWith("REEMPLAZAR")) return;

				var raw = window.sessionStorage.getItem("pt_auth");
				if (!raw) return;
				try {
					var user = JSON.parse(raw);
					var headers = {
						apikey: sbKey,
						Authorization: "Bearer " + sbKey,
						Prefer: "count=exact",
						Range: "0-0",
					};

					if (user.rol === "jefe") {
						var badge =
							document.getElementById("badge-trabajadores");
						if (!badge) return;
						var [r1, r2] = await Promise.all([
							fetch(
								sbUrl +
									"/rest/v1/employees?is_active=eq.true&termination_date=is.null&select=id",
								{ headers },
							),
							fetch(
								sbUrl +
									"/rest/v1/tareo_employee_config?select=id",
								{ headers },
							),
						]);
						var total = parseInt(
							r1.headers.get("Content-Range")?.split("/")[1] ??
								"0",
						);
						var conCfg = parseInt(
							r2.headers.get("Content-Range")?.split("/")[1] ??
								"0",
						);
						var sinCfg = Math.max(0, total - conCfg);
						badge.textContent = sinCfg > 0 ? String(sinCfg) : "";
						badge.style.display =
							sinCfg > 0 ? "inline-block" : "none";
					} else if (user.rol === "analista") {
						// Mejora 9: Badge analista observaciones pendientes
						var badgeObs =
							document.getElementById("badge-en-revision");
						if (!badgeObs) return;
						// Filtrar tareos_analista por analista_id y estado = en_revision
						var r3 = await fetch(
							sbUrl +
								"/rest/v1/tareos_analista?analista_id=eq." +
								user.id +
								"&estado=eq.en_revision&select=id",
							{ headers },
						);
						var enRev = parseInt(
							r3.headers.get("Content-Range")?.split("/")[1] ??
								"0",
						);
						badgeObs.textContent = enRev > 0 ? String(enRev) : "";
						badgeObs.style.display =
							enRev > 0 ? "inline-block" : "none";
					}
				} catch {
					/* silencioso */
				}
			}
			actualizarBadge();
			setInterval(actualizarBadge, 60000);
		</script>
	</body>
</html>
